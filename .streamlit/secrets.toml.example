# Copy this file to .streamlit/secrets.toml for LOCAL testing, or paste the same
# keys into "Settings -> Secrets" in the Streamlit Community Cloud app dashboard.
# NEVER commit a real secrets.toml (with real credentials) to GitHub.

# --- Recommended: private data via a Hugging Face dataset repo -------------
[huggingface]
repo_id       = "your-username/s22620-mnch-data"   # a PRIVATE HF dataset repo
data_filename = "survey_data.csv"                   # filename as uploaded to that repo
form_filename = "form.xlsx"                          # optional — omit to use the bundled form
token         = "hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"   # a read-only, repo-scoped HF token

# --- Optional: live SurveyCTO server instead of / alongside the above ------
[surveycto]
server   = "your-server-name"          # the part before .surveycto.com
form_id  = "S-22620_MNCH_FINAL"        # exact form_id from the XLSForm settings sheet
username = "your-surveycto-username"
password = "your-surveycto-password-or-api-key"
